{
  "name": "travel-helper",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered travel assistant with legal information, visa requirements, and trip planning",
  "scripts": {
    "mobile": "pnpm --filter @travel-helper/mobile",
    "web": "pnpm --filter @travel-helper/web",
    "api": "pnpm --filter @travel-helper/api",
    "shared": "pnpm --filter @travel-helper/shared",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:mobile\"",
    "dev:api": "pnpm --filter @travel-helper/api dev",
    "dev:web": "pnpm --filter @travel-helper/web dev",
    "dev:mobile": "pnpm --filter @travel-helper/mobile start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @travel-helper/api db:generate",
    "db:push": "pnpm --filter @travel-helper/api db:push",
    "db:migrate": "pnpm --filter @travel-helper/api db:migrate",
    "db:seed": "pnpm --filter @travel-helper/api db:seed",
    "db:studio": "pnpm --filter @travel-helper/api db:studio"
  },
  "keywords": [
    "travel",
    "ai",
    "visa",
    "trip-planning",
    "telegram-bot"
  ],
  "author": "Hugo",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
